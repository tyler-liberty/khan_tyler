# Required for PDF mapping and optional chat
OPENROUTER_API_KEY=your_token_here

# Optional (same as openrouter-webapp)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# Path to map-pacing-guide skill bin/ (contains ka-init, ka-parse-pacing-guide, ka-map-pipeline, etc.)
MAP_PACING_SKILL_BIN=/Users/tylerliberty/.claude/skills/map-pacing-guide/bin

# Optional: offline CCSS.Math table (same columns as GetSetOfStandards CSV). If unset or missing, the server calls KA GraphQL.
# KA_CCSS_MATH_CSV=/absolute/path/to/CCSS.Math.full.csv

# KA GetSetOfStandards (used whenever offline CCSS is not used for CCSS.Math, and for all other standard sets)
# KA_GRAPHQL_HASH=...              # if KA returns GraphQL errors, set from ka-standards-api --discover-hash
# KA_STANDARDS_URL_FIELD=state     # or "default" — URL column (matches ka-standards-api)
